# Provider API keys for real-Pi trials and the acceptance suite.
#
# Copy this file to `.env` and fill in the key(s) you have. These are read
# straight from the process environment — there is NO auto-loader, so you must
# get them into your shell yourself (direnv, `mise`, or `set -a; . ./.env; set +a`
# in bash/zsh). `.env` is gitignored; never commit real keys.
#
# The acceptance suite needs only ONE key — it picks the first provider whose
# key is set and runs that provider's small/cheap model:
#   GEMINI_API_KEY     -> google/gemini-2.5-flash
#   ANTHROPIC_API_KEY  -> anthropic/claude-haiku-4-5
#   OPENAI_API_KEY     -> openai/gpt-4o-mini
# (see python/tests/acceptance_support.py). With none set, acceptance tests skip.

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Also on the sandbox env allowlist (forwarded to Pi if set) — the Google SDK's
# alternate key name. Not used to select an acceptance-test model on its own.
GOOGLE_API_KEY=
