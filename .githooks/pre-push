#!/usr/bin/env bash
# Lint commit messages for conventional-commit compliance before push.
# committed checks only the commits being pushed (remote..local range).
set -euo pipefail

remote="$1"
remote_url="$2"

while IFS=' ' read -r local_ref local_oid remote_ref remote_oid; do
    # New branch with no upstream yet: check all commits since the merge base with main.
    if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
        base=$(git merge-base HEAD origin/main 2>/dev/null || git rev-list --max-parents=0 HEAD)
        range="${base}..${local_oid}"
    else
        range="${remote_oid}..${local_oid}"
    fi

    if [ -z "$(git log "$range" --oneline 2>/dev/null)" ]; then
        continue
    fi

    echo "committed: linting $(git log "$range" --oneline | wc -l | tr -d ' ') commit(s)…"
    committed "$range"
done
